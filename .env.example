# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-must-be-at-least-256-bits
JWT_EXPIRATION=86400000

# Database Configuration
# For H2 (Development)
DB_URL=jdbc:h2:mem:testdb
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver

# For MySQL (Production)
# DB_URL=jdbc:mysql://localhost:3306/rokdemo?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_DRIVER=com.mysql.cj.jdbc.Driver

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
H2_CONSOLE_ENABLED=true

# Logging
LOG_SQL=debug
LOG_SQL_PARAMS=trace

# Toss Payments Configuration (optional - if needed)
# TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
